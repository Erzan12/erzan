// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

enum UserRole {
  ADMINISTRATOR
  GUEST
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  DECLINED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(GUEST)

  password      String?   // for email/password login

  // Relations
  testimonials  Testimonials[]        @relation("UserTestimonials")
  givenFeedback TestimonialFeedback[] @relation("AdminFeedback")

  accounts      Account[]
  sessions      Session[]
  invitations   TestimonialInvitation[]

  posts         Post[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  excerpt         String?
  content         String   @db.Text // Stores MDX or HTML

  views           Int      @default(0)  
  coverImage      String?
  status          PostStatus
  published       Boolean? @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  authorId        String
  author          User     @relation(fields: [authorId], references: [id])
  
  tags            Tag[]
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  posts Post[]
}

model TestimonialInvitation {
  id           String   @id @default(cuid())

  email        String
  token        String   @unique

  status       InvitationStatus @default(PENDING)

  expires_at    DateTime
  accepted_at   DateTime?

  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Who sent invitation
  invited_by_id  String
  invited_by     User @relation(fields: [invited_by_id], references: [id], onDelete: Cascade)

  testimonial   Testimonials?

  @@index([email])
  @@index([status])
}

model Testimonials {
  id           String   @id @default(cuid())
  name         String 
  role         String?
  content      String   @db.Text
  avatar       String?  //store user iamge url at time of posting

  // Moderation States
  is_published  Boolean  @default(false)
  is_approved   Boolean  @default(false)
  is_active     Boolean  @default(true)

  // Relations
  userId       String   // The Guest who wrote it
  user         User     @relation("UserTestimonials", fields: [userId], references: [id], onDelete: Cascade)

  invitation_id String? @unique
  invitation   TestimonialInvitation? @relation(fields: [invitation_id], references: [id])

  // Feedback from Admin
  feedback     TestimonialFeedback?

  submitted_at DateTime?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([userId])
}

model TestimonialFeedback {
  id              String    @id @default(cuid())
  my_feedback     String    @db.Text

  testimonial_id  String    @unique
  testimonial     Testimonials @relation(fields: [testimonial_id], references: [id], onDelete: Cascade)

  // Who moderated this?
  adminId        String
  admin          User        @relation("AdminFeedback", fields: [adminId], references: [id]) 

  created_at      DateTime  @default(now())
}
